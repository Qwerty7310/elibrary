POSTGRES_DB=elibrary
POSTGRES_USER=elibrary
POSTGRES_PASSWORD=replace-with-strong-db-password

RABBITMQ_DEFAULT_USER=printer_user
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbit-password

JWT_SECRET=replace-with-long-random-jwt-secret

DB_URL=postgres://elibrary:replace-with-strong-db-password@postgres:5432/elibrary?sslmode=disable
RABBIT_URL=amqp://printer_user:replace-with-strong-rabbit-password@rabbitmq:5672/

HTTP_ADDR=:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
IMAGES_PATH=/app/data/images
IMAGES_URL=/static/images
RABBIT_QUEUE=print_queue
